# ClassFlow Environment Configuration
# Copy this file to .env and replace all REPLACE_THIS values.

# ── Database ─────────────────────────────────────────────────────────
# For local dev with SQLite (default if not set):
#   DATABASE_URL=sqlite:///data/schedule_test.db
# For Docker / production with PostgreSQL:
DATABASE_URL=postgresql+psycopg2://REPLACE_THIS_DB_USER:REPLACE_THIS_DB_PASSWORD@db:5432/REPLACE_THIS_DB_NAME

POSTGRES_DB=REPLACE_THIS_DB_NAME
POSTGRES_USER=REPLACE_THIS_DB_USER
POSTGRES_PASSWORD=REPLACE_THIS_DB_PASSWORD

# ── Security ─────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=REPLACE_THIS_JWT_SECRET

# Token lifetime in minutes (default: 1440 = 24h)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Environment ──────────────────────────────────────────────────────
# Values: development | production
ENVIRONMENT=development

# Set both to "true" to allow file imports in production
ALLOW_PRODUCTION_IMPORT=false

# ── Bootstrap Admin ──────────────────────────────────────────────────
# Only used on first startup when no users exist.
# Generate password with: python -c "import secrets; print(secrets.token_urlsafe(16))"
ADMIN_BOOTSTRAP_USERNAME=REPLACE_THIS_ADMIN_USER
ADMIN_BOOTSTRAP_PASSWORD=REPLACE_THIS_ADMIN_PASSWORD
ADMIN_BOOTSTRAP_EMAIL=REPLACE_THIS_ADMIN_EMAIL

# ── CORS ─────────────────────────────────────────────────────────────
# Comma-separated extra origins (optional)
CORS_EXTRA_ORIGINS=

# ── Frontend ─────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000
